modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && ./node_modules/.bin/cross-env NODE_OPTIONS=--max-old-space-size=6144 ./node_modules/.bin/next dev --webpack --port 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
EDUQUEST_PERSISTENCE_ADAPTER = "postgres"
NODE_ENV = "development"
PORT = "5000"
NEXT_PUBLIC_API_URL = ""
EDUQUEST_ALLOW_STATIC_FALLBACKS = "true"
EDUQUEST_ENABLE_LEGACY_AUTH = "true"
EDUQUEST_COOKIE_SECURE = "false"
NEXT_PUBLIC_CLERK_SIGN_IN_URL = "/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL = "/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL = "/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL = "/dashboard"
NEXT_TEST_WASM = "1"
EDUQUEST_SESSION_SECRET = "eduquest-replit-session-secret-2024-change-in-prod"

[nix]
channel = "stable-25_05"
