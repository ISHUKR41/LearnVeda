modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev -- --port 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
EDUQUEST_PERSISTENCE_ADAPTER = "postgres"
NODE_ENV = "development"
PORT = "5000"
NEXT_PUBLIC_API_URL = ""
EDUQUEST_ALLOW_STATIC_FALLBACKS = "true"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY = "pk_test_YWNjdXJhdGUtc2VydmFsLTYyLmNsZXJrLmFjY291bnRzLmRldiQ"
NEXT_PUBLIC_CLERK_SIGN_IN_URL = "/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL = "/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL = "/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL = "/dashboard"
EDUQUEST_ENABLE_LEGACY_AUTH = "true"
EDUQUEST_COOKIE_SECURE = "false"
CLERK_SECRET_KEY = "sk_test_dp3FP5E2lVw4ViEm0fjCI3ykCP00AbAwj87KnxBuc7"

[nix]
channel = "stable-25_05"
