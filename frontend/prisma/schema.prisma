generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Track the user's progress across chapters
  progress  ChapterProgress[]

  @@index([email]) // Index for fast lookups during authentication
}

model ChapterProgress {
  id           String   @id @default(uuid())
  userId       String
  chapterId    String   // e.g., "class-10-light"
  score        Int      @default(0) // For numericals solved
  completed    Boolean  @default(false)
  lastAccessed DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Compound index to quickly find a user's progress for a specific chapter
  // This is crucial for performance with 10k+ users
  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
}
